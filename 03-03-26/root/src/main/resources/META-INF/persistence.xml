<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://java.sun.com/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://java.sun.com/xml/ns/persistence http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd"
             version="2.0">
    <persistence-unit name="PU01">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.souro.hibernate_app.entity.Employee</class>
        <class>com.souro.hibernate_app.entity.SalaryRecord</class>
        <class>com.souro.hibernate_app.entity.PerformanceReview</class>
        <properties>
            <property name="javax.persistence.jdbc.driver"
                      value="org.postgresql.Driver" />
            <property name="javax.persistence.jdbc.url"
                      value="jdbc:postgresql://localhost:5432/employee_management_system_using_hibernate" />
            <property name="javax.persistence.jdbc.user" value="postgres" />
            <property name="javax.persistence.jdbc.password" value="0009" />
            <property name="hibernate.hbm2ddl.auto" value="update" />
            <property name="hibernate.show_sql" value="true" />
            <property name="hibernate.format_sql" value="true" />
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.PostgreSQLDialect" />
<!--            org.hibernate.dialect.PostgreSQLDialect : deprecated -->
        </properties>
    </persistence-unit>
</persistence>