<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Department Bean -->
    <bean id="department" class="com.souro.Department">
        <property name="departmentId" value="101" />
        <property name="departmentName" value="Engineering" />
    </bean>

    <!-- Employee Bean with Setter Injection -->
    <bean id="employee" class="com.souro.Employee">
        <property name="employeeId" value="1001" />
        <property name="employeeName" value="Sourojyoti Biswas" />
        <property name="salary" value="75000.00" />
        <!-- Bean reference injection for Department -->
        <!-- id -> ref -->
        <property name="department" ref="department" />
    </bean>

</beans>
